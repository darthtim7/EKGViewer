<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EKGViewer.MainPage">

    <Grid Padding="12" RowSpacing="8" RowDefinitions="Auto,Auto,*">

        <HorizontalStackLayout Grid.Row="0" Spacing="8">
            <Label Text="Record" VerticalOptions="Center" />
            <Picker x:Name="RecordPicker"
                    WidthRequest="140"
                    SelectedIndexChanged="OnRecordChanged" />

            <Label Text="Signal" VerticalOptions="Center" />
            <Picker x:Name="SignalPicker"
                    WidthRequest="140"
                    SelectedIndexChanged="OnSignalChanged" />
        </HorizontalStackLayout>

        <Label x:Name="InfoLabel"
               Grid.Row="1"
               Text="Loading..."
               FontSize="13" />

        <Grid Grid.Row="2" RowDefinitions="*,*" RowSpacing="8">
            <GraphicsView x:Name="EcgGraph"
                          Grid.Row="0" />

            <GraphicsView x:Name="HeartModel"
                          Grid.Row="1" />
        </Grid>
    </Grid>

